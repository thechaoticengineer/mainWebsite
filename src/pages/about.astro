---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import AboutImage from '../assets/about-profile.png';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="Software engineer navigating the chaos" />
		<style>
			/* Header */
			.about-header {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 16px;
				padding: 80px 120px;
			}
			.eyebrow {
				font-family: var(--font-code);
				font-size: 12px;
				font-weight: 500;
				color: var(--accent);
				letter-spacing: 3px;
			}
			.page-title {
				font-family: var(--font-mono);
				font-size: 48px;
				font-weight: 700;
				color: var(--fg);
				text-shadow: none;
				text-align: center;
				margin: 0;
				max-width: 800px;
			}

			.divider {
				height: 1px;
				background: var(--border);
			}

			/* Bio Section */
			.bio-section {
				display: flex;
				gap: 64px;
				padding: 64px 120px;
			}
			.bio-image {
				flex-shrink: 0;
				width: 350px;
				height: 400px;
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 8px 32px rgba(0, 255, 65, 0.25);
			}
			.bio-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border: none;
				border-radius: 0;
			}
			.bio-content {
				display: flex;
				flex-direction: column;
				gap: 24px;
			}
			.bio-title {
				font-family: var(--font-mono);
				font-size: 32px;
				font-weight: 700;
				color: var(--fg);
				text-shadow: none;
				margin: 0;
			}
			.bio-text {
				font-family: var(--font-sans);
				font-size: 16px;
				color: var(--fg-muted);
				line-height: 1.7;
				margin: 0;
			}

			/* Tech Stack */
			.tech-section {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 32px;
				padding: 64px 120px;
			}
			.tech-title {
				font-family: var(--font-mono);
				font-size: 28px;
				font-weight: 700;
				color: var(--fg);
				text-shadow: none;
				margin: 0;
			}
			.tech-grid {
				display: flex;
				align-items: center;
				gap: 24px;
				flex-wrap: wrap;
				justify-content: center;
			}
			.tech-badge {
				display: inline-flex;
				padding: 10px 20px;
				background: var(--surface-card);
				border: 1px solid var(--border);
				border-radius: 8px;
				font-family: var(--font-code);
				font-size: 14px;
				color: var(--accent);
				transition: all 0.2s ease;
			}
			.tech-badge:hover {
				border-color: var(--accent);
				box-shadow: 0 0 15px rgba(0, 255, 65, 0.2);
			}

			@media (max-width: 720px) {
				.about-header {
					padding: 48px 20px;
				}
				.page-title {
					font-size: 26px;
				}

				.bio-section {
					flex-direction: column;
					align-items: center;
					padding: 32px 20px;
					gap: 24px;
					text-align: center;
				}
				.bio-image {
					width: 200px;
					height: 240px;
				}
				.bio-title {
					font-size: 24px;
				}
				.bio-text {
					font-size: 14px;
				}

				.tech-section {
					padding: 32px 20px;
					gap: 20px;
				}
				.tech-title {
					font-size: 20px;
				}
				.tech-grid {
					gap: 12px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="about-header">
				<span class="eyebrow">ABOUT</span>
				<h1 class="page-title">The Engineer Behind the Chaos</h1>
			</section>

			<div class="divider"></div>

			<section class="bio-section">
				<div class="bio-image">
					<Image src={AboutImage} alt="Profile" width={350} height={400} />
				</div>
				<div class="bio-content">
					<h2 class="bio-title">Hi, I'm Lukasz</h2>
					<p class="bio-text">
						I've been a software engineer since 2017, working primarily with .NET, Angular, React, and Blazor.
						I'm passionate about clean code, solid architecture patterns, and the open-source ecosystem.
					</p>
					<p class="bio-text">
						This blog is my space to share thoughts that go beyond just code. It's about the people, the processes, and
						the patterns that make great engineering teams. I believe that culture eats strategy for breakfast, and that
						the best software is built by teams that trust each other.
					</p>
				</div>
			</section>

			<div class="divider"></div>

			<section class="tech-section">
				<h2 class="tech-title">Tech I Work With</h2>
				<div class="tech-grid">
					<span class="tech-badge">.NET</span>
					<span class="tech-badge">Angular</span>
					<span class="tech-badge">React</span>
					<span class="tech-badge">Blazor</span>
					<span class="tech-badge">Astro</span>
				</div>
			</section>

			<div class="divider"></div>
		</main>
		<Footer />
	</body>
</html>
