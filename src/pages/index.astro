---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>The Chaotic Engineer</h1>
			<p>
				Exploring the beautiful chaos of software engineering, one line of code at a time.
			</p>
			<p>
				Writing about engineering culture, team dynamics, and the things that actually matter
				when building software — beyond the code itself.
			</p>
			<p>
				<a href="/blog">Read the blog &rarr;</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
