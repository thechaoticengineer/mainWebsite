---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post, allPosts: posts },
	}));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

// Reading time
const words = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(words / 200));

// Related posts (shared tags, excluding current)
const currentTags = post.data.tags ?? [];
const relatedPosts = allPosts
	.filter((p: CollectionEntry<'blog'>) => p.id !== post.id)
	.map((p: CollectionEntry<'blog'>) => ({
		post: p,
		shared: (p.data.tags ?? []).filter((t: string) => currentTags.includes(t)).length,
	}))
	.filter((r: { shared: number }) => r.shared > 0)
	.sort((a: { shared: number }, b: { shared: number }) => b.shared - a.shared)
	.slice(0, 3)
	.map((r: { post: CollectionEntry<'blog'> }) => r.post);
---

<BlogPost {...post.data} readingTime={readingTime} headings={headings} relatedPosts={relatedPosts}>
	<Content />
</BlogPost>
