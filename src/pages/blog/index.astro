---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts[0];
const rest = posts.slice(1);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="Thoughts on engineering culture, team dynamics, and the chaos of building software." />
		<style>
			/* Blog Header */
			.blog-header {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 16px;
				padding: 64px 120px;
			}
			.eyebrow {
				font-family: var(--font-code);
				font-size: 12px;
				font-weight: 500;
				color: var(--accent);
				letter-spacing: 3px;
			}
			.page-title {
				font-family: var(--font-mono);
				font-size: 48px;
				font-weight: 700;
				color: var(--fg);
				text-shadow: none;
				margin: 0;
			}
			.page-subtitle {
				font-family: var(--font-sans);
				font-size: 18px;
				color: var(--fg-muted);
				text-align: center;
				max-width: 600px;
				line-height: 1.6;
			}

			/* Blog Grid */
			.blog-grid {
				display: flex;
				flex-direction: column;
				gap: 32px;
				padding: 0 120px 80px;
			}

			/* Featured Post */
			.featured {
				display: flex;
				background: var(--surface-card);
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 4px 20px rgba(0, 255, 65, 0.08);
				text-decoration: none;
				height: 360px;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.featured:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 30px rgba(0, 255, 65, 0.15);
				text-shadow: none;
			}
			.featured-image {
				width: 560px;
				flex-shrink: 0;
				overflow: hidden;
			}
			.featured-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border: none;
				border-radius: 0;
			}
			.featured-body {
				display: flex;
				flex-direction: column;
				justify-content: center;
				gap: 16px;
				padding: 32px;
				flex: 1;
			}
			.badge {
				display: inline-flex;
				align-self: flex-start;
				padding: 4px 12px;
				background: rgba(0, 255, 65, 0.13);
				border-radius: 9999px;
			}
			.badge span {
				font-family: var(--font-code);
				font-size: 11px;
				font-weight: 600;
				color: var(--accent);
			}
			.featured-date {
				font-family: var(--font-code);
				font-size: 12px;
				color: var(--accent-dark);
			}
			.featured-title {
				font-family: var(--font-mono);
				font-size: 28px;
				font-weight: 700;
				color: var(--fg);
				text-shadow: none;
				margin: 0;
				line-height: 1.2;
			}
			.featured-desc {
				font-family: var(--font-sans);
				font-size: 16px;
				color: var(--fg-muted);
				line-height: 1.6;
				margin: 0;
			}
			.read-more {
				font-family: var(--font-sans);
				font-size: 14px;
				font-weight: 600;
				color: var(--accent);
			}

			/* Cards Row */
			.cards-row {
				display: flex;
				gap: 32px;
			}
			.blog-card {
				display: flex;
				flex-direction: column;
				flex: 1;
				background: var(--surface-card);
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 4px 20px rgba(0, 255, 65, 0.08);
				text-decoration: none;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.blog-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 30px rgba(0, 255, 65, 0.15);
				text-shadow: none;
			}
			.card-image {
				width: 100%;
				height: 200px;
				overflow: hidden;
			}
			.card-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border: none;
				border-radius: 0;
			}
			.card-body {
				display: flex;
				flex-direction: column;
				gap: 12px;
				padding: 24px;
			}
			.card-date {
				font-family: var(--font-code);
				font-size: 12px;
				color: var(--accent-dark);
			}
			.card-title {
				font-family: var(--font-mono);
				font-size: 18px;
				font-weight: 600;
				color: var(--fg);
				text-shadow: none;
				margin: 0;
				line-height: 1.3;
			}
			.card-desc {
				font-family: var(--font-sans);
				font-size: 14px;
				color: var(--fg-muted);
				line-height: 1.5;
				margin: 0;
			}

			.card-tags {
				display: flex;
				gap: 6px;
				flex-wrap: wrap;
			}
			.card-tag {
				font-family: var(--font-code);
				font-size: 10px;
				font-weight: 500;
				color: var(--accent);
				background: rgba(0, 255, 65, 0.08);
				border: 1px solid rgba(0, 255, 65, 0.2);
				padding: 2px 8px;
				border-radius: 9999px;
			}

			.divider {
				height: 1px;
				background: var(--border);
			}

			@media (max-width: 720px) {
				.blog-header {
					padding: 48px 20px;
					gap: 12px;
				}
				.page-title {
					font-size: 32px;
				}
				.page-subtitle {
					font-size: 14px;
				}

				.blog-grid {
					padding: 0 20px 48px;
					gap: 20px;
				}
				.featured {
					flex-direction: column;
					height: auto;
				}
				.featured-image {
					width: 100%;
					height: 200px;
				}
				.featured-body {
					padding: 20px;
				}
				.featured-title {
					font-size: 22px;
				}
				.featured-desc {
					font-size: 14px;
				}

				.cards-row {
					flex-direction: column;
					gap: 20px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="blog-header">
				<span class="eyebrow">BLOG</span>
				<h1 class="page-title">All Posts</h1>
				<p class="page-subtitle">Thoughts on engineering culture, team dynamics, and the chaos of building software.</p>
			</section>

			<section class="blog-grid">
				{featured && (
					<a href={`/blog/${featured.id}/`} class="featured">
						{featured.data.heroImage && (
							<div class="featured-image">
								<Image src={featured.data.heroImage} alt="" width={560} height={360} />
							</div>
						)}
						<div class="featured-body">
							<div class="badge"><span>LATEST</span></div>
							<span class="featured-date"><FormattedDate date={featured.data.pubDate} /> &middot; {Math.max(1, Math.ceil((featured.body?.split(/\s+/).length ?? 0) / 200))} min read</span>
							<h2 class="featured-title">{featured.data.title}</h2>
							<p class="featured-desc">{featured.data.description}</p>
							{featured.data.tags?.length > 0 && (
								<div class="card-tags">
									{featured.data.tags.map((tag: string) => (
										<span class="card-tag">{tag}</span>
									))}
								</div>
							)}
							<span class="read-more">Read more &rarr;</span>
						</div>
					</a>
				)}

				{rest.length > 0 && (
					<div class="cards-row">
						{rest.map((post) => (
							<a href={`/blog/${post.id}/`} class="blog-card">
								{post.data.heroImage && (
									<div class="card-image">
										<Image src={post.data.heroImage} alt="" width={400} height={200} />
									</div>
								)}
								<div class="card-body">
									<span class="card-date"><FormattedDate date={post.data.pubDate} /> &middot; {Math.max(1, Math.ceil((post.body?.split(/\s+/).length ?? 0) / 200))} min read</span>
									<h3 class="card-title">{post.data.title}</h3>
									<p class="card-desc">{post.data.description}</p>
									{post.data.tags?.length > 0 && (
										<div class="card-tags">
											{post.data.tags.map((tag: string) => (
												<span class="card-tag">{tag}</span>
											))}
										</div>
									)}
									<span class="read-more">Read more &rarr;</span>
								</div>
							</a>
						))}
					</div>
				)}
			</section>

			<div class="divider"></div>
		</main>
		<Footer />
	</body>
</html>
