---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* Hero Image */
			.hero-image {
				position: relative;
				width: 100%;
				height: 400px;
				overflow: hidden;
			}
			.hero-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border: none;
				border-radius: 0;
			}
			.hero-gradient {
				position: absolute;
				inset: 0;
				background: linear-gradient(to bottom, transparent 0%, var(--surface) 100%);
			}

			/* Article */
			.article-content {
				display: flex;
				flex-direction: column;
				gap: 24px;
				padding: 48px 360px;
			}

			/* Meta */
			.meta {
				display: flex;
				align-items: center;
				gap: 16px;
			}
			.meta-date {
				font-family: var(--font-code);
				font-size: 13px;
				color: var(--accent-dark);
			}
			.meta-dot {
				font-size: 13px;
				color: var(--fg-muted);
			}
			.meta-read {
				font-family: var(--font-code);
				font-size: 13px;
				color: var(--fg-muted);
			}
			.last-updated {
				font-family: var(--font-code);
				font-size: 12px;
				color: var(--fg-muted);
				font-style: italic;
			}

			/* Title */
			.article-title {
				font-family: var(--font-mono);
				font-size: 42px;
				font-weight: 700;
				color: var(--fg);
				line-height: 1.2;
				text-shadow: none;
				margin: 0;
			}

			.article-divider {
				height: 1px;
				background: var(--border);
			}

			/* Prose */
			.prose {
				font-family: var(--font-sans);
				font-size: 17px;
				color: var(--fg);
				line-height: 1.8;
			}
			.prose h2 {
				font-family: var(--font-mono);
				font-size: 28px;
				font-weight: 700;
				color: var(--accent);
				text-shadow: none;
				margin: 1.5em 0 0.5em;
			}
			.prose h3 {
				font-family: var(--font-mono);
				font-size: 22px;
				font-weight: 700;
				color: var(--accent);
				text-shadow: none;
				margin: 1.2em 0 0.5em;
			}
			.prose p {
				margin-bottom: 1.5em;
			}
			.prose ul, .prose ol {
				margin-bottom: 1.5em;
				padding-left: 1.5em;
			}
			.prose li {
				margin-bottom: 0.5em;
			}

			/* Back Link */
			.back-link {
				font-family: var(--font-sans);
				font-size: 14px;
				font-weight: 600;
				color: var(--accent);
			}

			.bottom-divider {
				height: 1px;
				background: var(--border);
			}

			@media (max-width: 720px) {
				.hero-image {
					height: 220px;
				}
				.article-content {
					padding: 24px 20px;
					gap: 20px;
				}
				.meta {
					gap: 8px;
				}
				.article-title {
					font-size: 26px;
				}
				.prose {
					font-size: 15px;
					line-height: 1.7;
				}
				.prose h2 {
					font-size: 22px;
				}
				.prose h3 {
					font-size: 18px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1440} height={400} src={heroImage} alt="" />
						<div class="hero-gradient"></div>
					</div>
				)}
				<div class="article-content">
					<div class="meta">
						<span class="meta-date"><FormattedDate date={pubDate} /></span>
						{updatedDate && (
							<span class="last-updated">
								Updated <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>
					<h1 class="article-title">{title}</h1>
					<div class="article-divider"></div>
					<div class="prose">
						<slot />
					</div>
					<div class="article-divider"></div>
					<a href="/blog" class="back-link">&larr; Back to all posts</a>
				</div>
			</article>
			<div class="bottom-divider"></div>
		</main>
		<Footer />
	</body>
</html>
