---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	readingTime?: number;
	headings?: { depth: number; slug: string; text: string }[];
	relatedPosts?: CollectionEntry<'blog'>[];
};

const { title, description, pubDate, updatedDate, heroImage, tags, readingTime, headings, relatedPosts } = Astro.props;

const tocHeadings = (headings ?? []).filter((h) => h.depth === 2 || h.depth === 3);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			/* Hero Image */
			.hero-image {
				position: relative;
				width: 100%;
				height: 400px;
				overflow: hidden;
			}
			.hero-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border: none;
				border-radius: 0;
			}
			.hero-gradient {
				position: absolute;
				inset: 0;
				background: linear-gradient(to bottom, transparent 0%, var(--surface) 100%);
			}

			/* Article */
			.article-content {
				display: flex;
				flex-direction: column;
				gap: 24px;
				padding: 48px 360px;
			}

			/* Meta */
			.meta {
				display: flex;
				align-items: center;
				gap: 16px;
				flex-wrap: wrap;
			}
			.meta-date {
				font-family: var(--font-code);
				font-size: 13px;
				color: var(--accent-dark);
			}
			.meta-dot {
				font-size: 13px;
				color: var(--fg-muted);
			}
			.meta-read {
				font-family: var(--font-code);
				font-size: 13px;
				color: var(--fg-muted);
			}
			.last-updated {
				font-family: var(--font-code);
				font-size: 12px;
				color: var(--fg-muted);
				font-style: italic;
			}

			/* Tags */
			.tags {
				display: flex;
				gap: 8px;
				flex-wrap: wrap;
			}
			.tag {
				font-family: var(--font-code);
				font-size: 11px;
				font-weight: 500;
				color: var(--accent);
				background: rgba(0, 255, 65, 0.08);
				border: 1px solid rgba(0, 255, 65, 0.2);
				padding: 3px 10px;
				border-radius: 9999px;
				text-decoration: none;
				transition: all 0.2s ease;
			}
			.tag:hover {
				background: rgba(0, 255, 65, 0.15);
				text-shadow: none;
			}

			/* Title */
			.article-title {
				font-family: var(--font-mono);
				font-size: 42px;
				font-weight: 700;
				color: var(--fg);
				line-height: 1.2;
				text-shadow: none;
				margin: 0;
			}

			.article-divider {
				height: 1px;
				background: var(--border);
			}

			/* Table of Contents */
			.toc {
				background: var(--surface-card);
				border: 1px solid var(--border);
				border-radius: 8px;
				padding: 20px 24px;
			}
			.toc-title {
				font-family: var(--font-mono);
				font-size: 14px;
				font-weight: 600;
				color: var(--accent);
				text-shadow: none;
				margin: 0 0 12px;
				letter-spacing: 1px;
			}
			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 6px;
			}
			.toc-list a {
				font-family: var(--font-sans);
				font-size: 14px;
				color: var(--fg-muted);
				text-decoration: none;
				transition: color 0.2s ease;
			}
			.toc-list a:hover {
				color: var(--accent);
				text-shadow: none;
			}
			.toc-h3 {
				padding-left: 16px;
			}

			/* Prose */
			.prose {
				font-family: var(--font-sans);
				font-size: 17px;
				color: var(--fg);
				line-height: 1.8;
			}
			.prose h2 {
				font-family: var(--font-mono);
				font-size: 28px;
				font-weight: 700;
				color: var(--accent);
				text-shadow: none;
				margin: 1.5em 0 0.5em;
			}
			.prose h3 {
				font-family: var(--font-mono);
				font-size: 22px;
				font-weight: 700;
				color: var(--accent);
				text-shadow: none;
				margin: 1.2em 0 0.5em;
			}
			.prose p {
				margin-bottom: 1.5em;
			}
			.prose ul, .prose ol {
				margin-bottom: 1.5em;
				padding-left: 1.5em;
			}
			.prose li {
				margin-bottom: 0.5em;
			}

			/* Code block wrapper for copy button */
			.prose pre {
				position: relative;
			}

			/* Related Posts */
			.related-section {
				display: flex;
				flex-direction: column;
				gap: 20px;
			}
			.related-title {
				font-family: var(--font-mono);
				font-size: 18px;
				font-weight: 600;
				color: var(--accent);
				text-shadow: none;
				margin: 0;
			}
			.related-grid {
				display: flex;
				gap: 20px;
			}
			.related-card {
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: 8px;
				padding: 16px;
				background: var(--surface-card);
				border: 1px solid var(--border);
				border-radius: 8px;
				text-decoration: none;
				transition: all 0.2s ease;
			}
			.related-card:hover {
				border-color: rgba(0, 255, 65, 0.3);
				box-shadow: 0 4px 16px rgba(0, 255, 65, 0.1);
				transform: translateY(-2px);
				text-shadow: none;
			}
			.related-card-date {
				font-family: var(--font-code);
				font-size: 11px;
				color: var(--accent-dark);
			}
			.related-card-title {
				font-family: var(--font-mono);
				font-size: 15px;
				font-weight: 600;
				color: var(--fg);
				line-height: 1.3;
				margin: 0;
				text-shadow: none;
			}
			.related-card-tags {
				display: flex;
				gap: 6px;
				flex-wrap: wrap;
			}
			.related-tag {
				font-family: var(--font-code);
				font-size: 10px;
				color: var(--accent);
				background: rgba(0, 255, 65, 0.08);
				padding: 2px 8px;
				border-radius: 9999px;
			}

			/* Back Link */
			.back-link {
				font-family: var(--font-sans);
				font-size: 14px;
				font-weight: 600;
				color: var(--accent);
			}

			.bottom-divider {
				height: 1px;
				background: var(--border);
			}

			/* Copy button */
			.copy-btn {
				position: absolute;
				top: 8px;
				right: 8px;
				padding: 4px 10px;
				background: rgba(0, 255, 65, 0.1);
				border: 1px solid rgba(0, 255, 65, 0.2);
				border-radius: 4px;
				color: var(--accent);
				font-family: var(--font-code);
				font-size: 11px;
				cursor: pointer;
				opacity: 0;
				transition: opacity 0.2s ease, background 0.2s ease;
			}
			pre:hover .copy-btn {
				opacity: 1;
			}
			.copy-btn:hover {
				background: rgba(0, 255, 65, 0.2);
			}
			.copy-btn.copied {
				opacity: 1;
			}

			@media (max-width: 720px) {
				.hero-image {
					height: 220px;
				}
				.article-content {
					padding: 24px 20px;
					gap: 20px;
				}
				.meta {
					gap: 8px;
				}
				.article-title {
					font-size: 26px;
				}
				.prose {
					font-size: 15px;
					line-height: 1.7;
				}
				.prose h2 {
					font-size: 22px;
				}
				.prose h3 {
					font-size: 18px;
				}
				.related-grid {
					flex-direction: column;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1440} height={400} src={heroImage} alt="" />
						<div class="hero-gradient"></div>
					</div>
				)}
				<div class="article-content">
					<div class="meta">
						<span class="meta-date"><FormattedDate date={pubDate} /></span>
						{readingTime && (
							<>
								<span class="meta-dot">&middot;</span>
								<span class="meta-read">{readingTime} min read</span>
							</>
						)}
						{updatedDate && (
							<span class="last-updated">
								Updated <FormattedDate date={updatedDate} />
							</span>
						)}
					</div>
					<h1 class="article-title">{title}</h1>
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					)}
					<div class="article-divider"></div>
					{tocHeadings.length > 2 && (
						<nav class="toc">
							<p class="toc-title">TABLE OF CONTENTS</p>
							<ul class="toc-list">
								{tocHeadings.map((h) => (
									<li class={h.depth === 3 ? 'toc-h3' : ''}>
										<a href={`#${h.slug}`}>{h.text}</a>
									</li>
								))}
							</ul>
						</nav>
					)}
					<div class="prose">
						<slot />
					</div>
					{relatedPosts && relatedPosts.length > 0 && (
						<>
							<div class="article-divider"></div>
							<section class="related-section">
								<h2 class="related-title">Related Posts</h2>
								<div class="related-grid">
									{relatedPosts.map((rp: CollectionEntry<'blog'>) => (
										<a href={`/blog/${rp.id}/`} class="related-card">
											<span class="related-card-date"><FormattedDate date={rp.data.pubDate} /></span>
											<h3 class="related-card-title">{rp.data.title}</h3>
											<div class="related-card-tags">
												{(rp.data.tags ?? []).map((t: string) => (
													<span class="related-tag">{t}</span>
												))}
											</div>
										</a>
									))}
								</div>
							</section>
						</>
					)}
					<div class="article-divider"></div>
					<a href="/blog" class="back-link">&larr; Back to all posts</a>
				</div>
			</article>
			<div class="bottom-divider"></div>
		</main>
		<Footer />

		<script>
			document.querySelectorAll('pre').forEach((pre) => {
				const btn = document.createElement('button');
				btn.className = 'copy-btn';
				btn.textContent = 'Copy';
				btn.addEventListener('click', async () => {
					const code = pre.querySelector('code');
					if (code) {
						await navigator.clipboard.writeText(code.textContent ?? '');
						btn.textContent = 'Copied!';
						btn.classList.add('copied');
						setTimeout(() => {
							btn.textContent = 'Copy';
							btn.classList.remove('copied');
						}, 2000);
					}
				});
				pre.style.position = 'relative';
				pre.appendChild(btn);
			});
		</script>
	</body>
</html>
