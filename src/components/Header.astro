---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<button class="hamburger" aria-label="Toggle menu" aria-expanded="false">
			<span></span>
			<span></span>
			<span></span>
		</button>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const hamburger = document.querySelector('.hamburger');
		const nav = document.querySelector('nav');
		const internalLinks = document.querySelector('.internal-links');

		if (hamburger && nav && internalLinks) {
			hamburger.addEventListener('click', () => {
				nav.classList.toggle('menu-open');
				const isOpen = nav.classList.contains('menu-open');
				hamburger.setAttribute('aria-expanded', isOpen.toString());
			});

			// Close menu when clicking a link
			const links = internalLinks.querySelectorAll('a');
			links.forEach(link => {
				link.addEventListener('click', () => {
					nav.classList.remove('menu-open');
					hamburger.setAttribute('aria-expanded', 'false');
				});
			});
		}
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(var(--black), 0.95);
		backdrop-filter: blur(10px);
		box-shadow:
			0 2px 8px rgba(0, 255, 65, 0.2),
			0 0 20px rgba(0, 255, 65, 0.1);
		border-bottom: 1px solid rgba(0, 255, 65, 0.3);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1em;
		animation: none;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--accent);
		text-shadow: var(--text-glow-green);
		font-weight: 700;
		letter-spacing: 2px;
	}
	h2 a:hover {
		animation: glitch-intense 0.3s ease;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--gray-dark));
		border-bottom: 4px solid transparent;
		text-decoration: none;
		text-shadow: 0 0 2px rgba(0, 255, 65, 0.4);
		transition: all 0.3s ease;
	}
	nav a:hover {
		color: var(--accent);
		text-shadow: var(--text-glow-green);
		border-bottom-color: var(--accent);
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
		color: var(--accent);
		text-shadow: var(--text-glow-green);
	}

	/* Hamburger button - ukryty domyślnie */
	.hamburger {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0.5em;
		z-index: 101;
	}

	.hamburger span {
		display: block;
		width: 25px;
		height: 3px;
		background: var(--accent);
		transition: all 0.3s ease;
		box-shadow: 0 0 5px rgba(0, 255, 65, 0.5);
	}

	/* Animacja hamburger -> X */
	nav.menu-open .hamburger span:nth-child(1) {
		transform: translateY(8px) rotate(45deg);
	}

	nav.menu-open .hamburger span:nth-child(2) {
		opacity: 0;
	}

	nav.menu-open .hamburger span:nth-child(3) {
		transform: translateY(-8px) rotate(-45deg);
	}

	@media (max-width: 720px) {
		.hamburger {
			display: flex;
		}

		.internal-links {
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: rgba(var(--black), 0.98);
			backdrop-filter: blur(10px);
			flex-direction: column;
			padding: 0;
			max-height: 0;
			overflow: hidden;
			transition: max-height 0.3s ease, padding 0.3s ease;
			border-bottom: 1px solid transparent;
			box-shadow: none;
		}

		nav.menu-open .internal-links {
			max-height: 300px;
			padding: 1em 0;
			border-bottom-color: rgba(0, 255, 65, 0.3);
			box-shadow: 0 5px 20px rgba(0, 255, 65, 0.2);
		}

		.internal-links a {
			display: block;
			padding: 0.75em 1.5em;
			border-bottom: none;
			border-left: 3px solid transparent;
		}

		.internal-links a:hover,
		.internal-links a.active {
			border-left-color: var(--accent);
			border-bottom-color: transparent;
			background: rgba(0, 255, 65, 0.05);
		}

		nav {
			position: relative;
		}

		h2 {
			font-size: 0.9em;
		}

	}
</style>
