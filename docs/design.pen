              "type": "text",
              "id": "jeZaY",
              "name": "artP3",
              "fill": "$foreground-inverse",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The deployment pipeline is fully automated. Every push to main triggers a GitHub Action that builds and deploys to GitHub Pages.",
