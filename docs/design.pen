            {
              "type": "text",
              "id": "e6C5u",
              "name": "artTitle",
              "fill": "$foreground-inverse",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "How I Built and Deployed This Site",
              "lineHeight": 1.2,
              "fontFamily": "Geist Mono",
              "fontSize": 42,
              "fontWeight": "700"
            },
            {
              "type": "rectangle",
              "id": "kVL4L",
              "name": "artDivider",
              "fill": "$border-subtle",
              "width": "fill_container",
              "height": 1
            },
            {
              "type": "text",
              "id": "9sQVz",
              "name": "artP1",
              "fill": "$foreground-inverse",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "When I decided to create a personal blog, I had a few key requirements in mind. I wanted something fast, minimal, and easy to maintain. After evaluating several options, I landed on Astro — a modern static site generator that ships zero JavaScript by default.",
              "lineHeight": 1.8,
              "fontFamily": "Geist",
              "fontSize": 17,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "rsCWP",
              "name": "artH2",
              "fill": "$accent-primary",
              "content": "Why Astro?",
              "fontFamily": "Geist Mono",
              "fontSize": 28,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "ME9iF",
              "name": "artP2",
              "fill": "$foreground-inverse",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Astro is built for content-driven websites. It supports Markdown and MDX out of the box, generates static HTML at build time, and achieves perfect Lighthouse scores. The island architecture means you only ship JavaScript when you actually need interactivity.",
              "lineHeight": 1.8,
              "fontFamily": "Geist",
              "fontSize": 17,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "h9zAU",
              "name": "Code Block",
              "width": "fill_container",
              "fill": "#0D0D12",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "$border-subtle"
              },
              "layout": "vertical",
              "padding": 24,
              "children": [
                {
                  "type": "text",
                  "id": "NYbka",
                  "name": "codeLang",
                  "fill": "$accent-dark",
                  "content": "astro.config.mjs",
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "CDbVo",
                  "name": "codeContent",
                  "fill": "$accent-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "import { defineConfig } from 'astro/config';\nimport mdx from '@astrojs/mdx';\nimport sitemap from '@astrojs/sitemap';\n\nexport default defineConfig({\n  site: 'https://thechaotic.engineer',\n  integrations: [mdx(), sitemap()],\n});",
                  "lineHeight": 1.7,
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "mCzsz",
              "name": "artH3",
              "fill": "$accent-primary",
              "content": "Deployment with GitHub Actions",
              "fontFamily": "Geist Mono",
              "fontSize": 28,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "0ZGCA",
              "name": "artP3",
              "fill": "$foreground-inverse",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The deployment pipeline is fully automated. Every push to the main branch triggers a GitHub Action that builds the site and deploys it to GitHub Pages. The custom domain thechaotic.engineer is configured via a CNAME record.",
              "lineHeight": 1.8,
              "fontFamily": "Geist",
              "fontSize": 17,
              "fontWeight": "normal"
            },
            {
              "type": "rectangle",
              "id": "NhQIJ",
