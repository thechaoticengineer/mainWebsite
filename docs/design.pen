              "name": "artTitle",
              "fill": "$foreground-inverse",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "How I Built and Deployed This Site",
              "lineHeight": 1.2,
              "fontFamily": "Geist Mono",
              "fontSize": 26,
              "fontWeight": "700"
            },
            {
              "type": "rectangle",
              "id": "0mWNJ",
              "name": "artDiv",
              "fill": "$border-subtle",
              "width": "fill_container",
              "height": 1
            },
            {
              "type": "text",
              "id": "61FIo",
              "name": "artP1",
              "fill": "$foreground-inverse",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "When I decided to create a personal blog, I had a few key requirements in mind. I wanted something fast, minimal, and easy to maintain. After evaluating several options, I landed on Astro.",
              "lineHeight": 1.7,
              "fontFamily": "Geist",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "7PBp9",
              "name": "artH2",
              "fill": "$accent-primary",
              "content": "Why Astro?",
              "fontFamily": "Geist Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "9BZpu",
              "name": "artP2",
              "fill": "$foreground-inverse",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Astro is built for content-driven websites. It supports Markdown and MDX out of the box, generates static HTML at build time, and achieves perfect Lighthouse scores.",
              "lineHeight": 1.7,
              "fontFamily": "Geist",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "aKsSd",
              "name": "Code Block",
              "width": "fill_container",
              "fill": "#0D0D12",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "$border-subtle"
              },
              "layout": "vertical",
              "gap": 8,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "wlBvt",
                  "name": "codeLang",
                  "fill": "$accent-dark",
                  "content": "astro.config.mjs",
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 10,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "jaVUH",
                  "name": "codeContent",
                  "fill": "$accent-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "import { defineConfig } from\n  'astro/config';\nimport mdx from\n  '@astrojs/mdx';\n\nexport default defineConfig({\n  site: 'https://\n    thechaotic.engineer',\n  integrations: [\n    mdx(), sitemap()\n  ],\n});",
                  "lineHeight": 1.6,
                  "fontFamily": "IBM Plex Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "u975m",
              "name": "artH3",
              "fill": "$accent-primary",
              "content": "Deployment",
              "fontFamily": "Geist Mono",
              "fontSize": 22,
              "fontWeight": "700"
            },
